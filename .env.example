# Copy to ".env" for LOCAL testing (never commit the real .env).
# On GitHub these go in: repo Settings -> Secrets and variables -> Actions.
#
# One long-lived PAGE access token per Facebook Page:
FB_TOKEN_FCWXTH=paste_franklin_county_weather_page_token_here
FB_TOKEN_PVFD=paste_paden_fire_rescue_page_token_here

# Free NASA API key for the Astronomy Picture of the Day (get one instantly at
# api.nasa.gov). Optional — falls back to a shared rate-limited DEMO_KEY if unset.
NASA_API_KEY=paste_free_nasa_api_key_here

# Optional override (defaults to v21.0)
# GRAPH_VERSION=v21.0
